# Warplane environment variables
# Copy to .env and customize for your deployment.

WARPLANE_PORT=3000
WARPLANE_CONFIG=config/fuji-example.yaml
WARPLANE_LOG_LEVEL=info
DEMO_MODE=false

# SQLite database path (inside container)
# DB_PATH=/data/warplane.db

# Uncomment for Postgres mode (run with: docker compose --profile postgres up)
# DATABASE_URL=postgres://warplane:warplane-dev@postgres:5432/warplane
# POSTGRES_PASSWORD=warplane-dev
