# Warplane environment variables
# Copy to .env and customize for your deployment.

WARPLANE_PORT=3000
WARPLANE_LOG_LEVEL=info
DEMO_MODE=true

# Network config — choose one:
#   config/fuji-example.yaml           Fuji testnet only
#   config/mainnet-example.yaml        Mainnet only
#   config/multi-network-example.yaml  Both networks simultaneously
WARPLANE_CONFIG=config/multi-network-example.yaml

# Postgres connection string (required)
DATABASE_URL=postgresql://warplane:warplane-dev@localhost:5432/warplane

# Postgres password for docker-compose
# POSTGRES_PASSWORD=warplane-dev
