{
  "name": "@warplane/ingest",
  "version": "0.1.0",
  "private": true,
  "description": "Artifact ingestion pipeline — imports harness traces, manifests, and scenarios into storage",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "ingest": "node --import tsx src/cli.ts"
  },
  "dependencies": {
    "@warplane/domain": "workspace:*",
    "@warplane/storage": "workspace:*"
  }
}
