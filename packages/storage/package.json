{
  "name": "@warplane/storage",
  "version": "0.1.0",
  "private": true,
  "description": "Local SQLite persistence layer for traces, networks, chains, scenarios, and artifacts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "db:migrate": "node --import tsx src/cli-migrate.ts"
  },
  "dependencies": {
    "@warplane/domain": "workspace:*",
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  }
}
