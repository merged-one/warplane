{
  "name": "warplane",
  "private": true,
  "description": "Interchain Control Plane for Avalanche L1s",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run && pnpm --filter @warplane/web test",
    "check": "pnpm run lint && pnpm run typecheck",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "pnpm --filter @warplane/api run dev",
    "dev:web": "pnpm --filter @warplane/web run dev",
    "docs:dev": "pnpm --filter @warplane/docs-site run dev",
    "docs:build": "pnpm --filter @warplane/docs-site run build",
    "demo:seed": "bash scripts/demo-seed.sh",
    "repo:check": "bash scripts/check.sh",
    "docs:llms": "node scripts/generate-llms.mjs",
    "prepare": "[ -d .git ] && cp scripts/pre-commit.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit || true",
    "ai:pack": "bash scripts/ai-pack.sh",
    "ai:pack:docs": "bash scripts/ai-pack.sh docs",
    "mcp:docs": "pnpm --filter @warplane/docs-mcp run start",
    "db:migrate": "node --import tsx packages/storage/src/cli-migrate.ts",
    "db:seed": "node --import tsx packages/ingest/src/cli.ts import harness/tmpnet/artifacts",
    "ingest:fixtures": "node --import tsx packages/ingest/src/cli.ts import harness/tmpnet/artifacts",
    "ingest:watch": "node --import tsx packages/ingest/src/cli.ts watch harness/tmpnet/artifacts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
